// Royal Technosoft — Ed-Tech ERP
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  ADMISSION
  FACULTY
  STUDENT
}

enum FunnelStage {
  LEAD
  SEMINAR
  BOOTCAMP
  COUNSELING
  FOLLOWUP_1
  FOLLOWUP_2
  FOLLOWUP_3
  FOLLOWUP_4
  FOLLOWUP_5
  ADMISSION
}

enum InquiryReference {
  NEWS
  SOCIAL
  PEER
  OTHER
}

enum LectureStatus {
  PENDING
  LIVE
  ENDED
}

enum ResourceType {
  PDF
  CSV
  XLSX
  VIDEO
  ASSIGNMENT
}

enum FeeStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  REVOKED
}

enum NotificationAudience {
  ALL_STUDENTS
  BATCH
  INDIVIDUAL
}

// ─── Auth (NextAuth Prisma Adapter) ──────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  role          Role
  isActive      Boolean   @default(true)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]

  // Role-specific relations
  inquiriesAssigned Inquiry[]     @relation("InquiryAssignee")
  batchesTeaching   Batch[]       @relation("BatchFaculty")
  enrollments       Enrollment[]
  certificates      Certificate[]
  feedbackGiven     Feedback[]    @relation("FeedbackFaculty")
  feedbackReceived  Feedback[]    @relation("FeedbackStudent")
  fees              Fee[]
  notificationsSent Notification[] @relation("NotificationSender")
  assignmentSubmissions AssignmentSubmission[]

  @@index([role])
  @@index([isActive])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Admission CRM ───────────────────────────────────────────────────────────

model Inquiry {
  id        String           @id @default(cuid())
  firstName String
  middleName String?
  lastName  String
  city      String
  mobile    String
  dadOccupation String?
  dadMobile     String?
  momOccupation String?
  momMobile     String?
  reference InquiryReference
  stage     FunnelStage      @default(LEAD)
  notes     String?          @db.Text
  assigneeId String?
  assignee  User?            @relation("InquiryAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  stageHistory InquiryStageHistory[]

  @@index([stage])
  @@index([mobile])
}

model InquiryStageHistory {
  id        String      @id @default(cuid())
  inquiryId String
  inquiry   Inquiry     @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  fromStage FunnelStage?
  toStage   FunnelStage
  changedBy String?
  changedAt DateTime    @default(now())

  @@index([inquiryId])
}

// ─── Academics ───────────────────────────────────────────────────────────────

model Subject {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  batches BatchSubject[]
}

model Batch {
  id           String   @id @default(cuid())
  name         String
  maxStudents  Int
  days         String[] // e.g. ["MON", "WED", "FRI"]
  startTime    String   // scheduled slot, e.g. "09:00"
  endTime      String?
  facultyId    String
  faculty      User     @relation("BatchFaculty", fields: [facultyId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subjects     BatchSubject[]
  enrollments  Enrollment[]
  lectures     Lecture[]
  resources    Resource[]
  assignments  Assignment[]
  certificates Certificate[]
  notifications Notification[]

  @@index([facultyId])
}

model BatchSubject {
  batchId   String
  subjectId String
  batch     Batch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([batchId, subjectId])
}

model Enrollment {
  id        String   @id @default(cuid())
  studentId String
  batchId   String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  enrolledAt DateTime @default(now())

  @@unique([studentId, batchId])
  @@index([batchId])
}

model Lecture {
  id          String        @id @default(cuid())
  batchId     String
  batch       Batch         @relation(fields: [batchId], references: [id], onDelete: Cascade)
  title       String
  scheduledAt DateTime
  durationMin Int           @default(60)
  jitsiRoomId String        @unique
  status      LectureStatus @default(PENDING)
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([batchId, scheduledAt])
  @@index([status])
}

model Resource {
  id        String       @id @default(cuid())
  batchId   String
  batch     Batch        @relation(fields: [batchId], references: [id], onDelete: Cascade)
  title     String
  type      ResourceType
  url       String
  uploadedBy String?
  createdAt DateTime     @default(now())

  @@index([batchId, type])
}

model Assignment {
  id          String   @id @default(cuid())
  batchId     String
  batch       Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  title       String
  description String?  @db.Text
  dueAt       DateTime?
  maxScore    Int      @default(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions AssignmentSubmission[]
}

model AssignmentSubmission {
  id           String   @id @default(cuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  url          String?
  submittedAt  DateTime @default(now())
  score        Int?

  @@unique([assignmentId, studentId])
}

// ─── Student outcomes ────────────────────────────────────────────────────────

model Certificate {
  id        String   @id @default(cuid())
  studentId String
  batchId   String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  url       String
  isAuto    Boolean  @default(false)
  issuedAt  DateTime @default(now())

  @@unique([studentId, batchId])
}

model Feedback {
  id              String @id @default(cuid())
  studentId       String
  facultyId       String
  student         User   @relation("FeedbackStudent", fields: [studentId], references: [id], onDelete: Cascade)
  faculty         User   @relation("FeedbackFaculty", fields: [facultyId], references: [id], onDelete: Cascade)
  rateExplanation Int    // 1–5
  rateKnowledge   Int    // 1–5
  weekNo          Int
  comment         String? @db.Text
  createdAt       DateTime @default(now())

  @@unique([studentId, facultyId, weekNo])
  @@index([studentId, weekNo])
}

// ─── Finance & comms ─────────────────────────────────────────────────────────

model Fee {
  id        String    @id @default(cuid())
  studentId String
  student   User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  total     Decimal   @db.Decimal(12, 2)
  paid      Decimal   @default(0) @db.Decimal(12, 2)
  pending   Decimal   @db.Decimal(12, 2)
  status    FeeStatus @default(PENDING)
  dueDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  payments FeePayment[]

  @@index([studentId, status])
}

model FeePayment {
  id        String   @id @default(cuid())
  feeId     String
  fee       Fee      @relation(fields: [feeId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(12, 2)
  paidAt    DateTime @default(now())
  reference String?
  recordedBy String?
}

model Notification {
  id        String               @id @default(cuid())
  title     String
  body      String               @db.Text
  audience  NotificationAudience
  batchId   String?
  batch     Batch?               @relation(fields: [batchId], references: [id], onDelete: SetNull)
  targetUserId String?
  senderId  String?
  sender    User?                @relation("NotificationSender", fields: [senderId], references: [id], onDelete: SetNull)
  createdAt DateTime             @default(now())

  @@index([batchId])
  @@index([targetUserId])
}
